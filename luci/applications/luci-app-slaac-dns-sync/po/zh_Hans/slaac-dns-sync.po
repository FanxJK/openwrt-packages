"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Disabled"
msgstr "已禁用"

msgid "Running"
msgstr "运行中"

msgid "Stopped or starting"
msgstr "已停止或正在启动"

msgid "%d generated AAAA record(s)"
msgstr "已生成 %d 条 AAAA 记录"

msgid "Generated dnsmasq host records"
msgstr "已生成的 dnsmasq 主机记录"

msgid "No records have been generated yet. The router must first learn a named host IPv6 address through NDP."
msgstr "尚未生成记录。路由器需要先通过 NDP 学习到带有主机名的 IPv6 地址。"

msgid "SLAAC DNS Sync"
msgstr "SLAAC DNS 同步"

msgid "Publish local AAAA records by correlating OpenWrt LuCI host hints: DHCPv4/static host names provide the name, while NDP provides the actual SLAAC IPv6 address. DHCPv6 is not enabled or required."
msgstr "通过关联 OpenWrt LuCI 主机提示来发布本地 AAAA 记录：DHCPv4/静态主机提供名称，NDP 提供实际的 SLAAC IPv6 地址。无需启用 DHCPv6。"

msgid "Service"
msgstr "服务"

msgid "Current status"
msgstr "当前状态"

msgid "Enable SLAAC DNS synchronization"
msgstr "启用 SLAAC DNS 同步"

msgid "Master switch. Enabling starts the procd service; disabling stops it and removes the generated dnsmasq records."
msgstr "总开关。启用后启动 procd 服务；禁用后停止服务并删除已生成的 dnsmasq 记录。"

msgid "Manual synchronization"
msgstr "手动同步"

msgid "Immediately rebuild records from luci-rpc getHostHints."
msgstr "立即根据 luci-rpc getHostHints 重新生成记录。"

msgid "Synchronize now"
msgstr "立即同步"

msgid "Synchronization failed"
msgstr "同步失败"

msgid "SLAAC DNS records synchronized."
msgstr "SLAAC DNS 记录已同步。"

msgid "Address policy"
msgstr "地址策略"

msgid "IPv6 address policy"
msgstr "IPv6 地址策略"

msgid "Link-local, multicast, loopback and unspecified addresses are always excluded."
msgstr "始终排除链路本地、组播、环回和未指定地址。"

msgid "Prefer ULA; use GUA only when no ULA exists"
msgstr "优先 ULA；没有 ULA 时才使用 GUA"

msgid "Prefer GUA; use ULA only when no GUA exists"
msgstr "优先 GUA；没有 GUA 时才使用 ULA"

msgid "ULA only"
msgstr "仅 ULA"

msgid "GUA only"
msgstr "仅 GUA"

msgid "Publish both ULA and GUA"
msgstr "同时发布 ULA 和 GUA"

msgid "Local domain"
msgstr "本地域名"

msgid "Leave empty to inherit the domain from the first dnsmasq instance."
msgstr "留空则继承第一个 dnsmasq 实例的域名。"

msgid "Reconciliation interval"
msgstr "同步间隔"

msgid "Periodic synchronization interval in seconds. Interface changes also trigger synchronization."
msgstr "定期同步间隔（秒）。接口发生变化时也会触发同步。"

msgid "Require an IPv4 host hint"
msgstr "要求存在 IPv4 主机提示"

msgid "Only publish IPv6 neighbors that also have an IPv4 lease or static host hint. This avoids registering unrelated reverse-DNS names."
msgstr "只发布同时具有 IPv4 租约或静态主机提示的 IPv6 邻居，以避免注册无关的反向 DNS 名称。"

msgid "Publish short-name aliases"
msgstr "发布短主机名别名"

msgid "For example, publish both docker.lan and docker."
msgstr "例如同时发布 docker.lan 和 docker。"

msgid "Maximum addresses per host"
msgstr "每台主机最多地址数"

msgid "0 publishes all selected addresses. A positive limit cannot reliably distinguish stable RFC 7217 addresses from temporary RFC 4941 addresses."
msgstr "0 表示发布全部选中地址。正数限制无法可靠区分 RFC 7217 稳定地址和 RFC 4941 临时地址。"

msgid "Remove records when stopped"
msgstr "停止时删除记录"

msgid "Host filtering"
msgstr "主机过滤"

msgid "Included host names"
msgstr "包含的主机名"

msgid "Optional allowlist. Leave empty to include every named host. For servers, an allowlist such as docker and nas is recommended."
msgstr "可选白名单。留空表示包含所有带名称的主机。对于服务器，建议使用 docker、nas 等白名单。"

msgid "Excluded host names"
msgstr "排除的主机名"

msgid "Optional denylist. Exclusions take precedence over inclusions."
msgstr "可选黑名单。排除规则优先于包含规则。"

msgid "dnsmasq is configured to ignore /tmp/hosts. Set ignore_hosts_dir to 0 before enabling synchronization."
msgstr "dnsmasq 已配置为忽略 /tmp/hosts。启用同步前，请将 ignore_hosts_dir 设置为 0。"

msgid "dnsmasq is configured to filter AAAA records. Disable AAAA filtering before enabling synchronization."
msgstr "dnsmasq 已配置为过滤 AAAA 记录。启用同步前，请关闭 AAAA 过滤。"

msgid "Host name"
msgstr "主机名"

msgid "IPv4 address"
msgstr "IPv4 地址"

msgid "IPv6 address"
msgstr "IPv6 地址"

msgid "Delegated"
msgstr "委派"

msgid "Assigned"
msgstr "已分配"

msgid "Configured ULA"
msgstr "已配置 ULA"

msgid "No IPv6 prefix is currently reported by netifd."
msgstr "netifd 当前未报告 IPv6 前缀。"

msgid "IPv6 prefix"
msgstr "IPv6 前缀"

msgid "Source"
msgstr "来源"

msgid "Interface"
msgstr "接口"
