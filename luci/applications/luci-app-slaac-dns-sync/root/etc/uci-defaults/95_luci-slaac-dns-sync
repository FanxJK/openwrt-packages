#!/bin/sh

mkdir -p /var/lock
/etc/init.d/slaac-dns-sync enable >/dev/null 2>&1 || true

# Package upgrades replace the script on disk but do not stop an already
# running ucode process. Restart it when procd is available so the new code
# and syslog priorities take effect immediately.
if ubus -t 1 wait_for service >/dev/null 2>&1; then
	/etc/init.d/slaac-dns-sync restart >/dev/null 2>&1 || true
fi

rm -f /tmp/luci-indexcache
exit 0
