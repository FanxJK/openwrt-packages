config main 'main'
	# Controlled by the LuCI master switch. Disabled by default after install.
	option enabled '0'

	# Periodic reconciliation interval in seconds (10-3600).
	option interval '60'

	# Empty means inherit dhcp.@dnsmasq[0].domain, usually "lan".
	option domain 'lan'

	# Address selection policy:
	#   prefer_ula - publish ULA when present, otherwise GUA (recommended)
	#   prefer_gua - publish GUA when present, otherwise ULA
	#   ula        - publish only ULA
	#   gua        - publish only GUA
	#   all        - publish both ULA and GUA
	option address_mode 'prefer_ula'

	# Only publish hosts which also have an IPv4 hint/lease. This prevents
	# unrelated IPv6 neighbors from being registered under reverse-DNS names.
	option require_ipv4 '1'

	# Write both "docker.lan" and the short alias "docker".
	option include_short '1'

	# 0 publishes every selected address. A positive value limits addresses per
	# host after deterministic sorting, but cannot distinguish RFC 7217 stable
	# addresses from RFC 4941 temporary addresses.
	option max_addresses '0'

	# Remove generated records when the service is stopped.
	option remove_on_stop '1'

	# Empty include list means all named hosts. To publish only selected servers:
	# list include 'docker'
	# list include 'nas'

	# Optional exclusions always win over inclusions:
	# list exclude 'phone'
