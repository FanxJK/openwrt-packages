{
  "luci-app-fakehttp": {
    "description": "Grant UCI and payload file access for luci-app-fakehttp",
    "read": {
      "file": {
        "/var/run/fakehttp/*": [ "read" ],
        "/etc/fakehttp/payloads": [ "list" ],
        "/etc/fakehttp/payloads/*": [ "list", "read" ],
        "/etc/init.d/fakehttp": [ "exec" ]
      },
      "ubus": {
        "service": [ "list" ]
      },
      "uci": [ "fakehttp" ]
    },
    "write": {
      "uci": [ "fakehttp" ],
      "file": {
        "/etc/fakehttp/payloads/*": [ "write" ]
      }
    },
    "exec": {
      "/etc/init.d/fakehttp": [ "start", "stop", "restart", "status" ],
      "/bin/ps": [ "*" ]
    }
  }
}
